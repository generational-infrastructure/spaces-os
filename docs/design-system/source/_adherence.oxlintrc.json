{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/chat/**",
              "components/core/**",
              "ui_kits/pwa/**",
              "ui_kits/quickshell-panel/**",
              "ui_kits/shared/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Bubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:from|text|time|ack|tps|quote|variant|streaming|searchHit|searchCurrent|style|key|ref|className|style|children)$/]",
        "message": "<Bubble> doesn't accept that prop. Declared props: from, text, time, ack, tps, quote, variant, streaming, searchHit, searchCurrent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Bubble'] > JSXAttribute[name.name='from'] > Literal[value!=/^(?:me|peer)$/]",
        "message": "<Bubble> from must be one of 'me' | 'peer'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Bubble'] > JSXAttribute[name.name='ack'] > Literal[value!=/^(?:pending|sent|read|warn)$/]",
        "message": "<Bubble> ack must be one of 'pending' | 'sent' | 'read' | 'warn'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Bubble'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:text|notification|thinking)$/]",
        "message": "<Bubble> variant must be one of 'text' | 'notification' | 'thinking'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: icon, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|neutral|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'neutral' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConfirmCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|command|state|machine|answeredBy|onAllow|onDeny|style|key|ref|className|style|children)$/]",
        "message": "<ConfirmCard> doesn't accept that prop. Declared props: title, command, state, machine, answeredBy, onAllow, onDeny, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConfirmCard'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:pending|allowed|denied)$/]",
        "message": "<ConfirmCard> state must be one of 'pending' | 'allowed' | 'denied'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:vertical|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: vertical."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|title|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|size|active|title|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, size, active, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='MachineChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|color|status|relayed|size|variant|key|ref|className|style|children)$/]",
        "message": "<MachineChip> doesn't accept that prop. Declared props: name, color, status, relayed, size, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='MachineChip'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<MachineChip> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MachineChip'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|ghost|solid)$/]",
        "message": "<MachineChip> variant must be one of 'outline' | 'ghost' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|size|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: status, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:multiline|tone|value|onChange|placeholder|rows|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<TextInput> doesn't accept that prop. Declared props: multiline, tone, value, onChange, placeholder, rows, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|compose)$/]",
        "message": "<TextInput> tone must be one of 'default' | 'compose'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
