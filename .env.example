# Template for repo-local secrets. Copy to `.env` (gitignored) and fill
# in. direnv loads `.env` automatically via `.envrc` whenever you enter
# the project directory.
#
#   cp .env.example .env
#   $EDITOR .env
#   direnv allow

# Real OpenRouter key (https://openrouter.ai/keys). When set, the
# test-machine VM test switches its in-VM opencrow to the openrouter
# provider:
#   nix build --impure .#checks.x86_64-linux.test-machine
#   nix run --impure .#checks.x86_64-linux.test-machine.driverInteractive
# Leave unset to run the same test against the local llama-swap backend.
OPENROUTER_API_KEY=
