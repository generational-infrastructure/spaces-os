#!/bin/sh
# Stand-in for systemd-run inside the build sandbox. pi-sessiond spawns pi via
# `systemd-run --pipe --quiet --collect [--unit] [--working-directory]
# [--setenv=KEY=VAL …] [--property …] -- piBin …pi-args`. There is no systemd
# here, so we strip every flag, preserve --setenv assignments, and exec the
# tail (the fake pi). The sandbox properties don't matter for asserting the
# side-channel wire protocol; real confinement is covered by the VM tests.
env_args=""
while [ $# -gt 0 ]; do
  case "$1" in
    --setenv=*)
      env_args="$env_args ${1#--setenv=}"
      ;;
    --)
      shift
      break
      ;;
  esac
  shift
done
# shellcheck disable=SC2086
exec env $env_args "$@"
