#!/bin/sh
# Stand-in for `systemd-run --user --pipe …` used by PiSession.spawn().
# Strips every option until the `--` separator, then execs the program
# that follows. Lets the test exercise PiSession's stdio wiring without
# requiring a real user systemd manager inside the build sandbox.
while [ "$#" -gt 0 ]; do
  case "$1" in
    --) shift; exec "$@" ;;
    *) shift ;;
  esac
done
echo "fake-systemd-run: no -- separator in argv" >&2
exit 64
