#!/bin/sh
# Stand-in for `systemd-run --user --pipe …` used by PiSession.spawn().
# Strips every flag (and every --setenv/--property) up to the `--`
# separator, then execs the program that follows, inheriting this
# process's environment verbatim. The driver sets LLAMA_SWAP_BASE_URL,
# PI_CODING_AGENT_DIR, PI_OFFLINE, … in the quickshell environment so
# the real pi binary picks them up here without a user systemd manager.
while [ "$#" -gt 0 ]; do
  case "$1" in
    --) shift; exec "$@" ;;
    *) shift ;;
  esac
done
echo "fake-systemd-run: no -- separator in argv" >&2
exit 64
