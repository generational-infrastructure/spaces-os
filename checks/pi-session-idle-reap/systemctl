#!/bin/sh
# Stub `systemctl` placed first on PATH. PiSession.stop() reaps a worker
# with `systemctl --user stop pi-chat-<id>.service`; there is no user
# systemd manager in the build sandbox, so we record the argv to
# $SYSTEMCTL_WITNESS instead. The idle-reap check asserts WHICH units the
# reaper decided to stop (the idle one) and which it left alone (the
# busy background launch).
witness="${SYSTEMCTL_WITNESS:-/dev/null}"
printf '%s\n' "$*" >>"$witness" 2>/dev/null || true
exit 0
