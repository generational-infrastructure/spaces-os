+        // Per-permission map for security-context clients, loaded lazily
+        // from a file on first access. Format: one "<app-id> <permission>"
+        // line per grant; blank / '#'-comment lines skipped. Path comes
+        // from $NIRI_PERMISSION_MAP, defaulting to
+        // /etc/spaces/wayland-permissions.txt.
+        static PERMISSION_MAP: OnceLock<HashMap<String, HashSet<String>>> = OnceLock::new();
+        fn permission_map() -> &'static HashMap<String, HashSet<String>> {
+            PERMISSION_MAP.get_or_init(|| {
+                let path = std::env::var("NIRI_PERMISSION_MAP")
+                    .unwrap_or_else(|_| "/etc/spaces/wayland-permissions.txt".into());
+                let mut map: HashMap<String, HashSet<String>> = HashMap::new();
+                if let Ok(contents) = std::fs::read_to_string(&path) {
+                    for line in contents.lines() {
+                        let line = line.trim();
+                        if line.is_empty() || line.starts_with('#') {
+                            continue;
+                        }
+                        if let Some((id, perm)) = line.split_once(' ') {
+                            map.entry(id.to_string())
+                                .or_default()
+                                .insert(perm.trim().to_string());
+                        }
+                    }
+                }
+                map
+            })
+        }
+
+        // Granular gate. A non-restricted client always passes (matches the
+        // original behaviour). A restricted client passes iff its app-id has
+        // the named permission in the map; missing app-id or empty map = deny.
+        fn client_can(client: &Client, permission: &str) -> bool {
+            let state = client.get_data::<ClientState>().unwrap();
+            if !state.restricted {
+                return true;
+            }
+            state
+                .app_id
+                .as_ref()
+                .and_then(|id| permission_map().get(id))
+                .is_some_and(|perms| perms.contains(permission))
+        }
